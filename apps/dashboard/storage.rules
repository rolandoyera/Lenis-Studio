rules_version = '2';

// Storage rules for the SDG CRM (replaces expiring test-mode rules if present).
// Paste into Firebase console -> Storage -> Rules -> Publish.
//
// Uploads happen client-side from the dashboard (library + vendor images, org
// branding). Image display uses tokened download URLs, which work regardless of
// rules, so reads here only matter for direct SDK access. The firebase-admin SDK
// (server actions) bypasses these rules entirely.
//
// Tier 1: branding is org-scoped (the orgId in the path must match the uploader's
// profile org); every upload must be an image under the size cap; deletes are
// allowed (request.resource is null on delete).
//
// Tier 2 (current): new library/vendor uploads are written under
// `library/{orgId}/{itemId}/...` and `vendors/{orgId}/{vendorId}/...`, enforced by
// the org-scoped blocks below. The legacy FLAT blocks (`library/{p=**}`,
// `vendors/{p=**}`) are intentionally kept so existing files (stored at the old
// flat paths) still display and stored-path deletes still work. NOTE: while the
// flat blocks exist they also match the new org-scoped paths (Storage rules grant
// if ANY match allows), so cross-org isolation on library/vendors is only fully
// enforced once the flat blocks are removed — do that after existing files are
// migrated to the org-partitioned paths (or are no longer referenced).

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    // The uploader's organization, read from their users/{uid} profile.
    function userOrg() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.organizationId;
    }

    // request.resource is null on delete (always allowed for signed-in users);
    // on create/update it must be an image under the size cap.
    function validUpload() {
      return request.resource == null
        || (request.resource.contentType.matches('image/.*')
            && request.resource.size < 15 * 1024 * 1024);
    }

    // Org branding assets (light/dark logos and icon marks) uploaded from the
    // Company page. The orgId in the path must match the uploader's own org.
    match /organizations/{orgId}/branding/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && orgId == userOrg() && validUpload();
    }

    // Org-scoped library/vendor paths (Tier 2). New uploads write here; the orgId
    // in the path must match the uploader's own org.
    match /library/{orgId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && orgId == userOrg() && validUpload();
    }

    match /vendors/{orgId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && orgId == userOrg() && validUpload();
    }

    // Legacy flat paths — existing files predate the org partition. Kept so old
    // images keep displaying and stored-path deletes keep working. Remove these
    // two blocks once existing files are migrated (then org isolation above is
    // fully enforced). Auth-gated + upload-validated; deletes allowed.
    match /library/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && validUpload();
    }

    match /vendors/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && validUpload();
    }

    // Everything else: denied by default.
  }
}
