rules_version = '2';

// Storage rules for the SDG CRM (replaces expiring test-mode rules if present).
// Paste into Firebase console -> Storage -> Rules -> Publish.
//
// Uploads happen client-side from the dashboard (library + vendor images).
// Image display uses tokened download URLs, which work regardless of rules,
// so reads here only matter for direct SDK access.

service firebase.storage {
  match /b/{bucket}/o {
    match /library/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    match /vendors/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Everything else: denied by default.
  }
}
