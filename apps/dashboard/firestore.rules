rules_version = '2';

// Org-scoped rules for the SDG CRM (replaces the expiring test-mode rules).
// Deploy: `npx firebase deploy --only firestore:rules --project sarvian-design-group-db`
// (wired in firebase.json). Can also be pasted into Firebase console -> Firestore.
//
// Model: every signed-in user has a profile at users/{uid} carrying
// organizationId and role (SuperAdmin | Admin | Contributor). Data documents
// carry an organizationId field and are only visible inside that org.
// The firebase-admin SDK (server actions) bypasses these rules entirely.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // The requester's own profile document (one cached read per request).
    function me() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userOrg() {
      return me().organizationId;
    }

    function isAdmin() {
      return me().role in ['Admin', 'SuperAdmin'];
    }

    function isSuperAdmin() {
      return me().role == 'SuperAdmin';
    }

    // Org of a project document, for collections that only carry projectId.
    function projectOrg(projectId) {
      return get(/databases/$(database)/documents/projects/$(projectId)).data.organizationId;
    }

    // Org of a client document, for subcollections that inherit the parent's access.
    function clientOrg(clientId) {
      return get(/databases/$(database)/documents/clients/$(clientId)).data.organizationId;
    }

    // Shared shape for org-partitioned data collections.
    function readsOwnOrg() {
      return isSignedIn() && resource.data.organizationId == userOrg();
    }

    function createsInOwnOrg() {
      return isSignedIn() && request.resource.data.organizationId == userOrg();
    }

    function updatesInOwnOrg() {
      return isSignedIn()
        && resource.data.organizationId == userOrg()
        && request.resource.data.organizationId == resource.data.organizationId;
    }

    match /clients/{id} {
      allow read, delete: if readsOwnOrg();
      // Creation is server-only (createClient / convertLeadToClient, admin SDK)
      // so every client gets a reference code from the org counter. A client-SDK
      // create would bypass the sequence.
      allow create: if false;
      allow update: if updatesInOwnOrg();
    }

    // Append-only client notes. Each note carries organizationId and a
    // createdBy actor. Notes are immutable: the body is never editable. The
    // only permitted mutation is a creator-only soft-delete that stamps
    // deletedAt/deletedBy and touches nothing else. Notes are never
    // physically deleted.
    // Access is inherited from the parent client's org (not the doc's own
    // organizationId), so unfiltered list queries under this path are allowed —
    // a per-doc org check would make Firestore reject the list.
    match /clients/{clientId}/notes/{noteId} {
      allow read: if isSignedIn() && clientOrg(clientId) == userOrg();
      allow create: if isSignedIn()
        && clientOrg(clientId) == userOrg()
        && request.resource.data.organizationId == userOrg()
        && request.resource.data.createdBy.id == request.auth.uid
        && !('deletedAt' in request.resource.data);
      allow update: if isSignedIn()
        && clientOrg(clientId) == userOrg()
        && resource.data.createdBy.id == request.auth.uid
        && !('deletedAt' in resource.data)
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['deletedAt', 'deletedBy']);
      allow delete: if false;
    }

    // Activity log: a single top-level, append-only audit collection (NOT
    // per-entity subcollections). Each doc carries its own organizationId, so
    // access is a plain org check — no parent lookup needed, which also lets it
    // be written in the same batch as its source record. Append-only: create
    // within your own org, never update or delete (redaction deferred).
    match /activities/{activityId} {
      allow read: if isSignedIn() && resource.data.organizationId == userOrg();
      allow create: if createsInOwnOrg();
      allow update, delete: if false;
    }

    // In-app notifications: server-produced (admin SDK bypasses rules), fan-out
    // on read. `audience` is 'org' (every org member) or one recipient uid.
    // Members may ONLY append their own uid to readBy/dismissedBy — never
    // create, never delete, never remove entries or touch other fields.
    // Cleanup is a Firestore TTL policy on `expireAt`.
    // NOTE: list queries must constrain audience (in ['org', uid]) or the read
    // is rejected — rules OR on audience, and lists must be provably in-scope.
    match /notifications/{notificationId} {
      allow read: if readsOwnOrg()
        && (resource.data.audience == 'org'
            || resource.data.audience == request.auth.uid);
      allow create, delete: if false;
      allow update: if readsOwnOrg()
        && (resource.data.audience == 'org'
            || resource.data.audience == request.auth.uid)
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['readBy', 'dismissedBy'])
        // Append-only: nothing removed from either array…
        && request.resource.data.readBy.hasAll(resource.data.readBy)
        && request.resource.data.dismissedBy.hasAll(resource.data.dismissedBy)
        // …and anything added is exactly the requester's own uid.
        && request.resource.data.readBy.removeAll(resource.data.readBy)
             .hasOnly([request.auth.uid])
        && request.resource.data.dismissedBy.removeAll(resource.data.dismissedBy)
             .hasOnly([request.auth.uid]);
    }

    match /leads/{id} {
      allow read, delete: if readsOwnOrg();
      allow create: if createsInOwnOrg();
      allow update: if updatesInOwnOrg();
    }

    match /vendors/{id} {
      allow read, delete: if readsOwnOrg();
      allow create: if createsInOwnOrg();
      allow update: if updatesInOwnOrg();
    }

    match /projects/{id} {
      allow read, delete: if readsOwnOrg();
      // Creation is server-only (createProject, admin SDK) so every project gets a
      // reference code from the org counter. A client-SDK create would bypass it.
      allow create: if false;
      allow update: if updatesInOwnOrg();
    }

    // Editable project notes (working content, NOT an audit surface like client
    // notes). Each note carries organizationId and a createdBy actor; access is
    // inherited from the parent project's org so unfiltered list queries are
    // allowed. The author may edit the body (body/updatedAt/updatedBy only) and
    // hard-delete their own note. Org is the parent project's, not the doc's own.
    match /projects/{projectId}/notes/{noteId} {
      allow read: if isSignedIn() && projectOrg(projectId) == userOrg();
      allow create: if isSignedIn()
        && projectOrg(projectId) == userOrg()
        && request.resource.data.organizationId == userOrg()
        && request.resource.data.createdBy.id == request.auth.uid;
      allow update: if isSignedIn()
        && projectOrg(projectId) == userOrg()
        && resource.data.createdBy.id == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['body', 'updatedAt', 'updatedBy']);
      allow delete: if isSignedIn()
        && projectOrg(projectId) == userOrg()
        && resource.data.createdBy.id == request.auth.uid;
    }

    match /library/{id} {
      allow read, delete: if readsOwnOrg();
      allow create: if createsInOwnOrg();
      allow update: if updatesInOwnOrg();
    }

    match /proposals/{id} {
      allow read, delete: if readsOwnOrg();
      allow create: if createsInOwnOrg();
      allow update: if updatesInOwnOrg();
    }

    // Contracts carry their own organizationId (org-scoped reads/writes). A
    // contract is born a draft with no snapshot. Everything past draft — sending
    // (freeze + authorize + mint token), portal viewedAt/status, and signing/
    // execution — runs through the firebase-admin SDK (server-only), which
    // bypasses these rules. So the client SDK is confined to drafts:
    //   - create must start as a draft with lockedSnapshot null, carry the doc's
    //     own id, self-attribute createdBy/updatedBy, and hold ONLY the draft
    //     fields (no server-owned signature/lifecycle fields smuggled in), and
    //   - update is allowed ONLY while the contract stays a draft AND only the
    //     draft-editable fields change. The post-image is constrained (not just
    //     the pre-image) so a client can't flip status, write lockedSnapshot, or
    //     forge any server-owned lifecycle/signature field, and
    //   - delete is allowed ONLY while still a draft. Once sent, a contract is an
    //     audit record: it's locked to client writes entirely and can no longer be
    //     deleted client-side. Past-draft transitions (send, viewedAt, signing/
    //     execution, and voiding) all go through the firebase-admin SDK (server-
    //     only), which bypasses these rules — voiding stamps voidedBy/voidedAt
    //     server-side, never as a client write.
    // The create/update allowlists mirror the `Contract` write shape in
    // src/lib/types.ts (`ContractDraftInput` + the audit/identity fields
    // addContract/updateContract stamp) — keep them in sync.
    match /contracts/{id} {
      allow read: if readsOwnOrg();
      allow delete: if readsOwnOrg() && resource.data.status == 'draft';
      // Draft creation is server-only (createContract, admin SDK) so every contract
      // gets a reference code from the org counter. A client-SDK create would bypass
      // the sequence. Editing a draft stays a client surface (see update below).
      allow create: if false;
      allow update: if updatesInOwnOrg()
        && resource.data.status == 'draft'
        && request.resource.data.status == 'draft'
        && request.resource.data.get('lockedSnapshot', null) == null
        && request.resource.data.updatedBy == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
             'title', 'projectId', 'clientId', 'clientName', 'projectName',
             'templateKey', 'templateVersion', 'values', 'scopeItems',
             'updatedBy', 'updatedAt'
           ]);

      // Append-only audit trail (contract_sent, email_*, portal_opened, consent,
      // signed, executed) is written and read only by the server (admin SDK).
      // Deny all client access — it can carry IPs/UAs and raw provider refs.
      match /audit/{eventId} {
        allow read, write: if false;
      }
    }

    match /trades/{id} {
      allow read, delete: if readsOwnOrg();
      allow create: if createsInOwnOrg();
      allow update: if updatesInOwnOrg();
    }

    // Project-facing document references (the project "Files" tab). Each record
    // carries its own organizationId and just points at a file stored once in
    // Storage. Created/updated server-side only (admin SDK) — e.g. the executed
    // contract PDF reference written at signing — so client writes are denied;
    // org members may read their own org's documents.
    match /projectDocuments/{id} {
      allow read: if readsOwnOrg();
      allow write: if false;
    }

    // Token-gated pointers to contracts for the unauthenticated client portal.
    // All portal validation, viewedAt stamping, and link creation happen via the
    // firebase-admin SDK (server-only), which bypasses these rules — so client
    // writes are fully denied. Signed-in org members may read their own org's
    // records (e.g. to show "link sent" / "viewed" in the dashboard later); the
    // raw token never lives here, only its hash.
    match /portalAccess/{id} {
      allow read: if readsOwnOrg();
      allow write: if false;
    }

    // Rooms have no organizationId field; their org is the parent project's.
    // Queries must filter on projectId (the app always does).
    match /projectRooms/{id} {
      allow read, update, delete: if isSignedIn() && projectOrg(resource.data.projectId) == userOrg();
      allow create: if isSignedIn() && projectOrg(request.resource.data.projectId) == userOrg();
    }

    // Items are also queried by projectId, so the parent project drives access here too.
    match /projectRoomItems/{id} {
      allow read, update, delete: if isSignedIn() && projectOrg(resource.data.projectId) == userOrg();
      allow create: if isSignedIn()
        && projectOrg(request.resource.data.projectId) == userOrg()
        && request.resource.data.organizationId == userOrg();
    }

    match /users/{userId} {
      // The invite page verifies pending invites before the visitor has an account.
      // Exposes only invite docs (name/role/org) to someone who knows the exact email.
      allow get: if resource.data.status == 'Pending'
        || (isSignedIn() && (
          userId == request.auth.uid
          || userId == request.auth.token.email
          || resource.data.organizationId == userOrg()
          || isSuperAdmin()
        ));

      allow list: if isSignedIn() && (resource.data.organizationId == userOrg() || isSuperAdmin());

      // A pending invite doc for the requester's own email address.
      function pendingInvite() {
        return get(/databases/$(database)/documents/users/$(request.auth.token.email)).data;
      }

      function hasPendingInvite() {
        return exists(/databases/$(database)/documents/users/$(request.auth.token.email));
      }

      // Access is invite-only: a self-created profile must copy a pending
      // invite for the requester's email exactly (org and role included).
      function selfProfileAllowed() {
        return userId == request.auth.uid
          && hasPendingInvite()
          && request.resource.data.organizationId == pendingInvite().organizationId
          && request.resource.data.role == pendingInvite().role;
      }

      // Admins create pending invites inside their org; SuperAdmins for any org
      // (tenant onboarding creates the new org's first Admin invite).
      function inviteCreationAllowed() {
        return request.resource.data.status == 'Pending'
          && (isSuperAdmin() || (isAdmin() && request.resource.data.organizationId == userOrg()));
      }

      allow create: if isSignedIn() && (selfProfileAllowed() || inviteCreationAllowed());

      // Own profile edits (uid- or legacy email-keyed) must not touch role/org.
      allow update: if isSignedIn() && (
        ((userId == request.auth.uid || userId == request.auth.token.email)
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'organizationId']))
        || (isAdmin()
          && resource.data.organizationId == userOrg()
          && request.resource.data.organizationId == resource.data.organizationId)
        || isSuperAdmin()
      );

      // Users clean up their own pending invite after activation;
      // Admins manage users inside their org.
      allow delete: if isSignedIn() && (
        userId == request.auth.token.email
        || (isAdmin() && resource.data.organizationId == userOrg())
        || isSuperAdmin()
      );
    }

    match /organizations/{orgId} {
      // Members may read their own org (e.g. plan/config); only SuperAdmins see all.
      allow get: if isSignedIn() && (orgId == userOrg() || isSuperAdmin());
      allow list, create, delete: if isSignedIn() && isSuperAdmin();

      // Admins may edit their own org's Company Profile, but only those fields —
      // billing/identity fields (name, adminEmail, status, plan, config) stay
      // SuperAdmin-only. SuperAdmins keep full update access.
      allow update: if isSignedIn() && (
        isSuperAdmin()
        || (isAdmin()
          && orgId == userOrg()
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['companyProfile', 'branding', 'settings']))
      );

      // Integration secrets (Meta page access tokens, etc.) are server-only:
      // written and read exclusively via the firebase-admin SDK, never a client.
      match /secrets/{secretId} {
        allow read, write: if false;
      }

      // Reference-code sequences (client/project/contract numbering). Allocated
      // only inside server-side transactions (firebase-admin); a client must
      // never read or move the counter or it could desync the sequence.
      match /counters/{counterId} {
        allow read, write: if false;
      }
    }

    // Outbox for the Trigger Email extension. Mail is enqueued only by trusted
    // server actions via firebase-admin; clients must never write arbitrary
    // recipients/subjects/HTML into the email outbox.
    match /mail/{mailId} {
      allow read, write: if false;
    }

    // Internal diagnostics runs (no org partition; dev tooling).
    match /code/{runId} {
      allow read, write: if isSignedIn();
    }

    // Everything else: denied by default.
  }
}
