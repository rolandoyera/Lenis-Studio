[debug] [2026-06-28T23:54:39.828Z] <<< [apiv2][status] POST https://firebaserules.googleapis.com/v1/projects/sarvian-design-group-db/rulesets 200
[debug] [2026-06-28T23:54:39.828Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/sarvian-design-group-db/rulesets {"name":"projects/sarvian-design-group-db/rulesets/c81e797b-60be-450e-a027-5fe45c069aff","source":{"files":[{"content":"rules_version = '2';\r\n\r\n// Org-scoped rules for the SDG CRM (replaces the expiring test-mode rules).\r\n// Deploy: `npx firebase deploy --only firestore:rules --project sarvian-design-group-db`\r\n// (wired in firebase.json). Can also be pasted into Firebase console -> Firestore.\r\n//\r\n// Model: every signed-in user has a profile at users/{uid} carrying\r\n// organizationId and role (SuperAdmin | Admin | Contributor). Data documents\r\n// carry an organizationId field and are only visible inside that org.\r\n// The firebase-admin SDK (server actions) bypasses these rules entirely.\r\n\r\nservice cloud.firestore {\r\n  match /databases/{database}/documents {\r\n\r\n    function isSignedIn() {\r\n      return request.auth != null;\r\n    }\r\n\r\n    // The requester's own profile document (one cached read per request).\r\n    function me() {\r\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;\r\n    }\r\n\r\n    function userOrg() {\r\n      return me().organizationId;\r\n    }\r\n\r\n    function isAdmin() {\r\n      return me().role in ['Admin', 'SuperAdmin'];\r\n    }\r\n\r\n    function isSuperAdmin() {\r\n      return me().role == 'SuperAdmin';\r\n    }\r\n\r\n    // Org of a project document, for collections that only carry projectId.\r\n    function projectOrg(projectId) {\r\n      return get(/databases/$(database)/documents/projects/$(projectId)).data.organizationId;\r\n    }\r\n\r\n    // Org of a client document, for subcollections that inherit the parent's access.\r\n    function clientOrg(clientId) {\r\n      return get(/databases/$(database)/documents/clients/$(clientId)).data.organizationId;\r\n    }\r\n\r\n    // Shared shape for org-partitioned data collections.\r\n    function readsOwnOrg() {\r\n      return isSignedIn() && resource.data.organizationId == userOrg();\r\n    }\r\n\r\n    function createsInOwnOrg() {\r\n      return isSignedIn() && request.resource.data.organizationId == userOrg();\r\n    }\r\n\r\n    function updatesInOwnOrg() {\r\n      return isSignedIn()\r\n        && resource.data.organizationId == userOrg()\r\n        && request.resource.data.organizationId == resource.data.organizationId;\r\n    }\r\n\r\n    match /clients/{id} {\r\n      allow read, delete: if readsOwnOrg();\r\n      // Creation is server-only (createClient / convertLeadToClient, admin SDK)\r\n      // so every client gets a reference code from the org counter. A client-SDK\r\n      // create would bypass the sequence.\r\n      allow create: if false;\r\n      allow update: if updatesInOwnOrg();\r\n    }\r\n\r\n    // Append-only client notes. Each note carries organizationId and a\r\n    // createdBy actor. Notes are immutable: the body is never editable. The\r\n    // only permitted mutation is a creator-only soft-delete that stamps\r\n    // deletedAt/deletedBy and touches nothing else. Notes are never\r\n    // physically deleted.\r\n    // Access is inherited from the parent client's org (not the doc's own\r\n    // organizationId), so unfiltered list queries under this path are allowed —\r\n    // a per-doc org check would make Firestore reject the list.\r\n    match /clients/{clientId}/notes/{noteId} {\r\n      allow read: if isSignedIn() && clientOrg(clientId) == userOrg();\r\n      allow create: if isSignedIn()\r\n        && clientOrg(clientId) == userOrg()\r\n        && request.resource.data.organizationId == userOrg()\r\n        && request.resource.data.createdBy.id == request.auth.uid\r\n        && !('deletedAt' in request.resource.data);\r\n      allow update: if isSignedIn()\r\n        && clientOrg(clientId) == userOrg()\r\n        && resource.data.createdBy.id == request.auth.uid\r\n        && !('deletedAt' in resource.data)\r\n        && request.resource.data.diff(resource.data).affectedKeys()\r\n             .hasOnly(['deletedAt', 'deletedBy']);\r\n      allow delete: if false;\r\n    }\r\n\r\n    // Activity log: a single top-level, append-only audit collection (NOT\r\n    // per-entity subcollections). Each doc carries its own organizationId, so\r\n    // access is a plain org check — no parent lookup needed, which also lets it\r\n    // be written in the same batch as its source record. Append-only: create\r\n    // within your own org, never update or delete (redaction deferred).\r\n    match /activities/{activityId} {\r\n      allow read: if isSignedIn() && resource.data.organizationId == userOrg();\r\n      allow create: if createsInOwnOrg();\r\n      allow update, delete: if false;\r\n    }\r\n\r\n    match /leads/{id} {\r\n      allow read, delete: if readsOwnOrg();\r\n      allow create: if createsInOwnOrg();\r\n      allow update: if updatesInOwnOrg();\r\n    }\r\n\r\n    match /vendors/{id} {\r\n      allow read, delete: if readsOwnOrg();\r\n      allow create: if createsInOwnOrg();\r\n      allow update: if updatesInOwnOrg();\r\n    }\r\n\r\n    match /projects/{id} {\r\n      allow read, delete: if readsOwnOrg();\r\n      // Creation is server-only (createProject, admin SDK) so every project gets a\r\n      // reference code from the org counter. A client-SDK create would bypass it.\r\n      allow create: if false;\r\n      allow update: if updatesInOwnOrg();\r\n    }\r\n\r\n    match /library/{id} {\r\n      allow read, delete: if readsOwnOrg();\r\n      allow create: if createsInOwnOrg();\r\n      allow update: if updatesInOwnOrg();\r\n    }\r\n\r\n    match /proposals/{id} {\r\n      allow read, delete: if readsOwnOrg();\r\n      allow create: if createsInOwnOrg();\r\n      allow update: if updatesInOwnOrg();\r\n    }\r\n\r\n    // Contracts carry their own organizationId (org-scoped reads/writes). A\r\n    // contract is born a draft with no snapshot. Everything past draft — sending\r\n    // (freeze + authorize + mint token), portal viewedAt/status, and signing/\r\n    // execution — runs through the firebase-admin SDK (server-only), which\r\n    // bypasses these rules. So the client SDK is confined to drafts:\r\n    //   - create must start as a draft with lockedSnapshot null, carry the doc's\r\n    //     own id, self-attribute createdBy/updatedBy, and hold ONLY the draft\r\n    //     fields (no server-owned signature/lifecycle fields smuggled in), and\r\n    //   - update is allowed ONLY while the contract stays a draft AND only the\r\n    //     draft-editable fields change. The post-image is constrained (not just\r\n    //     the pre-image) so a client can't flip status, write lockedSnapshot, or\r\n    //     forge any server-owned lifecycle/signature field, and\r\n    //   - delete is allowed ONLY while still a draft. Once sent, a contract is an\r\n    //     audit record: it's locked to client writes entirely and can no longer be\r\n    //     deleted client-side. Past-draft transitions (send, viewedAt, signing/\r\n    //     execution, and voiding) all go through the firebase-admin SDK (server-\r\n    //     only), which bypasses these rules — voiding stamps voidedBy/voidedAt\r\n    //     server-side, never as a client write.\r\n    // The create/update allowlists mirror the `Contract` write shape in\r\n    // src/lib/types.ts (`ContractDraftInput` + the audit/identity fields\r\n    // addContract/updateContract stamp) — keep them in sync.\r\n    match /contracts/{id} {\r\n      allow read: if readsOwnOrg();\r\n      allow delete: if readsOwnOrg() && resource.data.status == 'draft';\r\n      // Draft creation is server-only (createContract, admin SDK) so every contract\r\n      // gets a reference code from the org counter. A client-SDK create would bypass\r\n      // the sequence. Editing a draft stays a client surface (see update below).\r\n      allow create: if false;\r\n      allow update: if updatesInOwnOrg()\r\n        && resource.data.status == 'draft'\r\n        && request.resource.data.status == 'draft'\r\n        && request.resource.data.get('lockedSnapshot', null) == null\r\n        && request.resource.data.updatedBy == request.auth.uid\r\n        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([\r\n             'title', 'projectId', 'clientId', 'clientName', 'projectName',\r\n             'templateKey', 'templateVersion', 'values', 'scopeItems',\r\n             'updatedBy', 'updatedAt'\r\n           ]);\r\n\r\n      // Append-only audit trail (contract_sent, email_*, portal_opened, consent,\r\n      // signed, executed) is written and read only by the server (admin SDK).\r\n      // Deny all client access — it can carry IPs/UAs and raw provider refs.\r\n      match /audit/{eventId} {\r\n        allow read, write: if false;\r\n      }\r\n    }\r\n\r\n    match /trades/{id} {\r\n      allow read, delete: if readsOwnOrg();\r\n      allow create: if createsInOwnOrg();\r\n      allow update: if updatesInOwnOrg();\r\n    }\r\n\r\n    // Project-facing document references (the project \"Files\" tab). Each record\r\n    // carries its own organizationId and just points at a file stored once in\r\n    // Storage. Created/updated server-side only (admin SDK) — e.g. the executed\r\n    // contract PDF reference written at signing — so client writes are denied;\r\n    // org members may read their own org's documents.\r\n    match /projectDocuments/{id} {\r\n      allow read: if readsOwnOrg();\r\n      allow write: if false;\r\n    }\r\n\r\n    // Token-gated pointers to contracts for the unauthenticated client portal.\r\n    // All portal validation, viewedAt stamping, and link creation happen via the\r\n    // firebase-admin SDK (server-only), which bypasses these rules — so client\r\n    // writes are fully denied. Signed-in org members may read their own org's\r\n    // records (e.g. to show \"link sent\" / \"viewed\" in the dashboard later); the\r\n    // raw token never lives here, only its hash.\r\n    match /portalAccess/{id} {\r\n      allow read: if readsOwnOrg();\r\n      allow write: if false;\r\n    }\r\n\r\n    // Rooms have no organizationId field; their org is the parent project's.\r\n    // Queries must filter on projectId (the app always does).\r\n    match /projectRooms/{id} {\r\n      allow read, update, delete: if isSignedIn() && projectOrg(resource.data.projectId) == userOrg();\r\n      allow create: if isSignedIn() && projectOrg(request.resource.data.projectId) == userOrg();\r\n    }\r\n\r\n    // Items are also queried by projectId, so the parent project drives access here too.\r\n    match /projectRoomItems/{id} {\r\n      allow read, update, delete: if isSignedIn() && projectOrg(resource.data.projectId) == userOrg();\r\n      allow create: if isSignedIn()\r\n        && projectOrg(request.resource.data.projectId) == userOrg()\r\n        && request.resource.data.organizationId == userOrg();\r\n    }\r\n\r\n    match /users/{userId} {\r\n      // The invite page verifies pending invites before the visitor has an account.\r\n      // Exposes only invite docs (name/role/org) to someone who knows the exact email.\r\n      allow get: if resource.data.status == 'Pending'\r\n        || (isSignedIn() && (\r\n          userId == request.auth.uid\r\n          || userId == request.auth.token.email\r\n          || resource.data.organizationId == userOrg()\r\n          || isSuperAdmin()\r\n        ));\r\n\r\n      allow list: if isSignedIn() && (resource.data.organizationId == userOrg() || isSuperAdmin());\r\n\r\n      // A pending invite doc for the requester's own email address.\r\n      function pendingInvite() {\r\n        return get(/databases/$(database)/documents/users/$(request.auth.token.email)).data;\r\n      }\r\n\r\n      function hasPendingInvite() {\r\n        return exists(/databases/$(database)/documents/users/$(request.auth.token.email));\r\n      }\r\n\r\n      // Access is invite-only: a self-created profile must copy a pending\r\n      // invite for the requester's email exactly (org and role included).\r\n      function selfProfileAllowed() {\r\n        return userId == request.auth.uid\r\n          && hasPendingInvite()\r\n          && request.resource.data.organizationId == pendingInvite().organizationId\r\n          && request.resource.data.role == pendingInvite().role;\r\n      }\r\n\r\n      // Admins create pending invites inside their org; SuperAdmins for any org\r\n      // (tenant onboarding creates the new org's first Admin invite).\r\n      function inviteCreationAllowed() {\r\n        return request.resource.data.status == 'Pending'\r\n          && (isSuperAdmin() || (isAdmin() && request.resource.data.organizationId == userOrg()));\r\n      }\r\n\r\n      allow create: if isSignedIn() && (selfProfileAllowed() || inviteCreationAllowed());\r\n\r\n      // Own profile edits (uid- or legacy email-keyed) must not touch role/org.\r\n      allow update: if isSignedIn() && (\r\n        ((userId == request.auth.uid || userId == request.auth.token.email)\r\n          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'organizationId']))\r\n        || (isAdmin()\r\n          && resource.data.organizationId == userOrg()\r\n          && request.resource.data.organizationId == resource.data.organizationId)\r\n        || isSuperAdmin()\r\n      );\r\n\r\n      // Users clean up their own pending invite after activation;\r\n      // Admins manage users inside their org.\r\n      allow delete: if isSignedIn() && (\r\n        userId == request.auth.token.email\r\n        || (isAdmin() && resource.data.organizationId == userOrg())\r\n        || isSuperAdmin()\r\n      );\r\n    }\r\n\r\n    match /organizations/{orgId} {\r\n      // Members may read their own org (e.g. plan/config); only SuperAdmins see all.\r\n      allow get: if isSignedIn() && (orgId == userOrg() || isSuperAdmin());\r\n      allow list, create, delete: if isSignedIn() && isSuperAdmin();\r\n\r\n      // Admins may edit their own org's Company Profile, but only those fields —\r\n      // billing/identity fields (name, adminEmail, status, plan, config) stay\r\n      // SuperAdmin-only. SuperAdmins keep full update access.\r\n      allow update: if isSignedIn() && (\r\n        isSuperAdmin()\r\n        || (isAdmin()\r\n          && orgId == userOrg()\r\n          && request.resource.data.diff(resource.data).affectedKeys()\r\n               .hasOnly(['companyProfile', 'branding', 'settings']))\r\n      );\r\n\r\n      // Integration secrets (Meta page access tokens, etc.) are server-only:\r\n      // written and read exclusively via the firebase-admin SDK, never a client.\r\n      match /secrets/{secretId} {\r\n        allow read, write: if false;\r\n      }\r\n\r\n      // Reference-code sequences (client/project/contract numbering). Allocated\r\n      // only inside server-side transactions (firebase-admin); a client must\r\n      // never read or move the counter or it could desync the sequence.\r\n      match /counters/{counterId} {\r\n        allow read, write: if false;\r\n      }\r\n    }\r\n\r\n    // Outbox for the Trigger Email extension. Mail is enqueued only by trusted\n    // server actions via firebase-admin; clients must never write arbitrary\n    // recipients/subjects/HTML into the email outbox.\n    match /mail/{mailId} {\n      allow read, write: if false;\n    }\n\r\n    // Internal diagnostics runs (no org partition; dev tooling).\r\n    match /code/{runId} {\r\n      allow read, write: if isSignedIn();\r\n    }\r\n\r\n    // Everything else: denied by default.\r\n  }\r\n}\r\n","name":"firestore.rules"}]},"createTime":"2026-06-28T23:54:39.764447Z","metadata":{"services":["cloud.firestore"]}}
